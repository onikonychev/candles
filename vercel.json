{
  "outputDirectory": ".",
  "rewrites": [
    { "source": "/candles/udf/(.*)", "destination": "https://sai-candles.nibiru.fi/candles/udf/$1" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=60" }
      ]
    }
  ]
}
